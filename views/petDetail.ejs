<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title><%= pet.name %> - Pet Shelter Portal</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Pet Shelter Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/pets">Browse Pets</a></li>
          <li class="nav-item"><a class="nav-link" href="/favourites">Favourites</a></li>
          <li class="nav-item"><a class="nav-link" href="/my-applications">My Applications</a></li>
          <% if (user.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/addPet">Add Pet</a></li>
            <li class="nav-item"><a class="nav-link" href="/applications">Manage Applications</a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              👤 <%= user.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
              <li><a class="dropdown-item" href="/profile">My Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="row">
      <div class="col-md-5">
        <img src="/images/<%= pet.image || 'placeholder.png' %>" class="img-fluid rounded" alt="<%= pet.name %>">
      </div>
      <div class="col-md-7">
        <h1><%= pet.name %> <span class="badge bg-secondary"><%= pet.adoptionStatus %></span></h1>
        <p class="text-muted"><%= pet.breed %> &middot; <%= pet.species %> &middot; <%= pet.ageGroup %> (<%= pet.ageMonths %> months) &middot; <%= pet.gender %></p>
        <p><%= pet.description %></p>

        <ul class="list-group list-group-flush mb-3">
          <li class="list-group-item">Personality: <%= pet.personality %></li>
          <li class="list-group-item">Weight: <%= pet.weightLbs %> lbs</li>
          <li class="list-group-item">Vaccination Status: <%= pet.vaccinationStatus %></li>
          <li class="list-group-item">Medical History: <%= pet.medicalHistory %></li>
          <li class="list-group-item">Shelter Location: <%= pet.shelterLocation %> (<%= pet.kennelCode %>)</li>
          <li class="list-group-item">
            Good with:
            <%= pet.friendlyWithKids ? 'Kids' : '' %>
            <%= pet.friendlyWithDogs ? ' Dogs' : '' %>
            <%= pet.friendlyWithCats ? ' Cats' : '' %>
            <%= pet.friendlyWithOtherPets ? ' Other Pets' : '' %>
            <% if (!pet.friendlyWithKids && !pet.friendlyWithDogs && !pet.friendlyWithCats && !pet.friendlyWithOtherPets) { %>Not specified<% } %>
          </li>
          <% if (pet.specialNeeds) { %><li class="list-group-item">This pet has special needs.</li><% } %>
        </ul>

        <form action="/pets/<%= pet.id %>/favourite" method="POST" class="d-inline">
          <button type="submit" class="btn btn-outline-danger">
            <%= isFavourite ? 'Remove from Favourites' : 'Add to Favourites' %>
          </button>
        </form>

        <% if (pet.adoptionStatus === 'Available') { %>
          <a href="/apply/<%= pet.id %>" class="btn btn-primary">Apply to Adopt</a>
        <% } %>

        <% if (user.role === 'admin') { %>
          <a href="/editPet/<%= pet.id %>" class="btn btn-secondary">Edit</a>
          <a href="/deletePet/<%= pet.id %>" class="btn btn-danger" onclick="return confirm('Are you sure you want to remove this pet?')">Delete</a>
        <% } %>
      </div>
    </div>
  </div>
</body>
</html>
