<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Apply to Adopt <%= pet.name %></title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Pet Shelter Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/pets">Browse Pets</a></li>
          <li class="nav-item"><a class="nav-link" href="/my-applications">My Applications</a></li>
          <% if (user.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/addPet">Add Pet</a></li>
            <li class="nav-item"><a class="nav-link" href="/applications">Manage Applications</a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              👤 <%= user.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
              <li><a class="dropdown-item" href="/profile">My Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4" style="max-width: 650px;">
    <h2 class="mb-4">Adoption Application for <%= pet.name %></h2>
    <form action="/apply/<%= pet.id %>" method="POST">
      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Living Space</label>
          <select class="form-select" name="livingSpace" required>
            <option value="Apartment">Apartment</option>
            <option value="Townhome">Townhome</option>
            <option value="House">House</option>
            <option value="Farm">Farm</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Working Hours</label>
          <select class="form-select" name="workingHours" required>
            <option value="Remote">Remote</option>
            <option value="Hybrid">Hybrid</option>
            <option value="Office 0-4 hours">Office 0-4 hours</option>
            <option value="Office 5-8 hours">Office 5-8 hours</option>
            <option value="Office 9+ hours">Office 9+ hours</option>
          </select>
        </div>
      </div>

      <div class="row mb-3">
        <div class="col-md-6">
          <label class="form-label">Number of Family Members</label>
          <input type="number" class="form-control" name="familyMembers" min="1" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Activity Level</label>
          <select class="form-select" name="activityLevel" required>
            <option value="Low">Low</option>
            <option value="Moderate">Moderate</option>
            <option value="High">High</option>
            <option value="Very High">Very High</option>
          </select>
        </div>
      </div>

      <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" name="hasChildren" id="hasChildren">
        <label class="form-check-label" for="hasChildren">I have children at home</label>
      </div>

      <div class="mb-3">
        <label class="form-label">Existing Pets</label>
        <input type="text" class="form-control" name="existingPets" placeholder="e.g. None, or 1 dog">
      </div>

      <div class="mb-3">
        <label class="form-label">Pet Ownership Experience</label>
        <textarea class="form-control" name="experience" rows="3" required></textarea>
      </div>

      <div class="mb-4">
        <label class="form-label">Why do you want to adopt <%= pet.name %>?</label>
        <textarea class="form-control" name="motivation" rows="3" required></textarea>
      </div>

      <button type="submit" class="btn btn-primary">Submit Application</button>
    </form>
  </div>
</body>
</html>
