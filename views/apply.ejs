<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Apply to Adopt <%= pet.name %></title>
</head>
<body>
  <%- include('header') %>
  <div class="container mt-4" style="max-width: 700px;">
    <div class="page-heading">
      <div class="icon-badge">📝</div>
      <div>
        <h2>Adopt <%= pet.name %></h2>
        <p>Tell us a bit about yourself so our team can get to know you.</p>
      </div>
    </div>

    <div class="form-card">
      <form action="/apply/<%= pet.id %>" method="POST">
        <fieldset>
          <legend>Your Home</legend>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Living Space</label>
              <select class="form-select" name="livingSpace" required>
                <option value="Apartment (1-2 Room)">Apartment (1-2 Room)</option>
                <option value="Apartment (3+ Room)">Apartment (3+ Room)</option>
                <option value="Condominium">Condominium</option>
                <option value="Landed House">Landed House</option>
                <option value="Farm">Farm</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Working Hours</label>
              <select class="form-select" name="workingHours" required>
                <option value="Remote">Remote</option>
                <option value="Hybrid">Hybrid</option>
                <option value="Office 0-4 hours">Office 0-4 hours</option>
                <option value="Office 5-8 hours">Office 5-8 hours</option>
                <option value="Office 9+ hours">Office 9+ hours</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Number of Family Members</label>
              <input type="number" class="form-control" name="familyMembers" min="1" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Activity Level</label>
              <select class="form-select" name="activityLevel" required>
                <option value="Low">Low</option>
                <option value="Moderate">Moderate</option>
                <option value="High">High</option>
                <option value="Very High">Very High</option>
              </select>
            </div>
          </div>
          <div class="form-check">
            <input type="checkbox" class="form-check-input" name="hasChildren" id="hasChildren">
            <label class="form-check-label" for="hasChildren">I have children at home</label>
          </div>
        </fieldset>

        <fieldset>
          <legend>About You</legend>
          <div class="mb-3">
            <label class="form-label">Existing Pets</label>
            <input type="text" class="form-control" name="existingPets" placeholder="e.g. None, or 1 dog">
          </div>
          <div class="mb-3">
            <label class="form-label">Pet Ownership Experience</label>
            <textarea class="form-control" name="experience" rows="3" required></textarea>
          </div>
          <div class="mb-0">
            <label class="form-label">Why do you want to adopt <%= pet.name %>?</label>
            <textarea class="form-control" name="motivation" rows="3" required></textarea>
          </div>
        </fieldset>

        <div class="d-grid">
          <button type="submit" class="btn btn-primary btn-lg">Submit Application</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
