<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Edit <%= pet.name %> - Pet Shelter Portal</title>
</head>
<body>
  <%- include('header') %>

  <div class="container mt-4" style="max-width: 760px;">
    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(e) { %><p class="mb-0"><%= e %></p><% }); %>
      </div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(m) { %><p class="mb-0"><%= m %></p><% }); %>
      </div>
    <% } %>

    <div class="page-heading">
      <div class="icon-badge">✏️</div>
      <div>
        <h2>Edit <%= pet.name %></h2>
        <p>Update this pet's listing details.</p>
      </div>
    </div>

    <div class="form-card">
      <form action="/editPet/<%= pet.id %>" method="POST" enctype="multipart/form-data">

        <fieldset>
          <legend>Basic Info</legend>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Name</label>
              <input type="text" class="form-control" name="name" value="<%= pet.name %>" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Species</label>
              <select class="form-select" name="species" required>
                <% ['Dog','Cat','Rabbit','Bird','Other'].forEach(s => { %>
                  <option value="<%= s %>" <%= pet.species === s ? 'selected' : '' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Breed</label>
              <input type="text" class="form-control" name="breed" value="<%= pet.breed %>" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Age (months)</label>
              <input type="number" class="form-control" name="ageMonths" value="<%= pet.ageMonths %>" min="0" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Age Group</label>
              <select class="form-select" name="ageGroup" required>
                <% ['Baby','Young','Adult','Senior'].forEach(a => { %>
                  <option value="<%= a %>" <%= pet.ageGroup === a ? 'selected' : '' %>><%= a %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="col-md-4">
              <label class="form-label">Gender</label>
              <select class="form-select" name="gender" required>
                <% ['Male','Female','Unknown'].forEach(g => { %>
                  <option value="<%= g %>" <%= pet.gender === g ? 'selected' : '' %>><%= g %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Weight (lbs)</label>
              <input type="number" step="0.1" class="form-control" name="weightLbs" value="<%= pet.weightLbs %>" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Adoption Status</label>
              <select class="form-select" name="adoptionStatus">
                <% ['Available','Pending','Adopted','Medical Hold','Archived'].forEach(st => { %>
                  <option value="<%= st %>" <%= pet.adoptionStatus === st ? 'selected' : '' %>><%= st %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>About This Pet</legend>
          <div class="mb-3">
            <label class="form-label">Personality</label>
            <textarea class="form-control" name="personality" rows="2" required><%= pet.personality %></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="description" rows="3" required><%= pet.description %></textarea>
          </div>
          <div class="mb-0">
            <label class="form-label">Medical History</label>
            <textarea class="form-control" name="medicalHistory" rows="2"><%= pet.medicalHistory %></textarea>
          </div>
        </fieldset>

        <fieldset>
          <legend>Shelter Details</legend>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Vaccination Status</label>
              <input type="text" class="form-control" name="vaccinationStatus" value="<%= pet.vaccinationStatus %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Rescue Date</label>
              <input type="date" class="form-control" name="rescueDate" value="<%= pet.rescueDate ? pet.rescueDate.toISOString().split('T')[0] : '' %>">
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <label class="form-label">Shelter Location</label>
              <input type="text" class="form-control" name="shelterLocation" value="<%= pet.shelterLocation %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Kennel Code</label>
              <input type="text" class="form-control" name="kennelCode" value="<%= pet.kennelCode %>">
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Temperament &amp; Health</legend>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithPeople" <%= pet.friendlyWithPeople ? 'checked' : '' %>>
            <label class="form-check-label">Good with people</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithKids" <%= pet.friendlyWithKids ? 'checked' : '' %>>
            <label class="form-check-label">Good with kids</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithDogs" <%= pet.friendlyWithDogs ? 'checked' : '' %>>
            <label class="form-check-label">Good with dogs</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithCats" <%= pet.friendlyWithCats ? 'checked' : '' %>>
            <label class="form-check-label">Good with cats</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithOtherPets" <%= pet.friendlyWithOtherPets ? 'checked' : '' %>>
            <label class="form-check-label">Good with other pets</label>
          </div>
          <br>
          <div class="form-check form-check-inline mt-2">
            <input class="form-check-input" type="checkbox" name="specialNeeds" <%= pet.specialNeeds ? 'checked' : '' %>>
            <label class="form-check-label">Special needs</label>
          </div>
          <div class="form-check form-check-inline mt-2">
            <input class="form-check-input" type="checkbox" name="healthy" <%= pet.healthy ? 'checked' : '' %>>
            <label class="form-check-label">Currently healthy</label>
          </div>
        </fieldset>

        <fieldset>
          <legend>Photo</legend>
          <img src="/images/pet/<%= pet.id %>" style="max-height:120px; border-radius: 0.6rem;" class="mb-2 d-block"><br>
          <label class="form-label">Replace Photo (optional)</label>
          <input class="form-control" type="file" name="image" accept="image/*">
        </fieldset>

        <div class="d-grid">
          <button type="submit" class="btn btn-primary btn-lg">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
