<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Manage Applications - Pet Shelter Portal</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Pet Shelter Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/pets">Browse Pets</a></li>
          <li class="nav-item"><a class="nav-link" href="/addPet">Add Pet</a></li>
          <li class="nav-item"><a class="nav-link" href="/applications">Manage Applications</a></li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              👤 <%= user.username %> <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %><span class="badge rounded-pill bg-danger"><%= unreadCount %></span><% } %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
              <li><a class="dropdown-item" href="/notifications">🔔 Notifications</a></li>
              <li><a class="dropdown-item" href="/profile">My Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(e) { %><p class="mb-0"><%= e %></p><% }); %>
      </div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(m) { %><p class="mb-0"><%= m %></p><% }); %>
      </div>
    <% } %>
    <h2 class="text-center mb-4">Manage Adoption Applications</h2>
    <table class="table table-hover small text-center align-middle">
      <thead>
        <tr>
          <th>Applicant</th>
          <th>Pet</th>
          <th>Family/Living</th>
          <th>Current Stage</th>
          <th>Update Stage</th>
        </tr>
      </thead>
      <tbody>
        <% applications.forEach(a => { %>
          <tr>
            <td><%= a.applicantName %><br><small class="text-muted"><%= a.applicantEmail %></small></td>
            <td><%= a.petName %></td>
            <td><%= a.livingSpace %>, <%= a.familyMembers %> members</td>
            <td><span class="badge bg-info text-dark"><%= a.stage %></span></td>
            <td>
              <form action="/applications/<%= a.id %>/stage" method="POST" class="d-flex gap-1 justify-content-center">
                <select name="stage" class="form-select form-select-sm" style="width:auto;">
                  <% ['Submitted','Under Review','Interview Scheduled','Home Visit','Approved','Rejected','Completed'].forEach(st => { %>
                    <option value="<%= st %>" <%= a.stage === st ? 'selected' : '' %>><%= st %></option>
                  <% }) %>
                </select>
                <input type="text" name="decisionNotes" class="form-control form-control-sm" placeholder="Notes" value="<%= a.decisionNotes || '' %>" style="width:140px;">
                <button type="submit" class="btn btn-sm btn-primary">Update</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</body>
</html>
