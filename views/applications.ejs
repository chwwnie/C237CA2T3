<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Manage Applications - Pet Shelter Portal</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Pet Shelter Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/pets">Browse Pets</a></li>
          <li class="nav-item"><a class="nav-link" href="/addPet">Add Pet</a></li>
          <li class="nav-item"><a class="nav-link" href="/applications">Manage Applications</a></li>
        </ul>
        <ul class="navbar-nav align-items-center">
          <li class="nav-item">
            <a class="nav-link position-relative px-3" href="/notifications" title="Notifications" aria-label="Notifications">
              <span style="font-size:1.15rem;">&#128276;</span>
              <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;">
                  <%= unreadCount %>
                </span>
              <% } %>
            </a>
          </li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              &#128100; <%= user.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
              <li><a class="dropdown-item" href="/profile">My Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(e) { %><p class="mb-0"><%= e %></p><% }); %>
      </div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(m) { %><p class="mb-0"><%= m %></p><% }); %>
      </div>
    <% } %>
    <h2 class="text-center mb-4">Manage Adoption Applications</h2>
    <% if (applications.length === 0) { %>
      <p class="text-center text-muted">No applications yet.</p>
    <% } %>
    <div class="d-flex flex-column gap-3">
      <% applications.forEach(a => { %>
        <div class="card shadow-sm">
          <div class="card-body">
            <div class="row align-items-center gy-2">
              <div class="col-md-3">
                <div class="fw-semibold"><%= a.applicantName %></div>
                <div class="text-muted small"><%= a.applicantEmail %></div>
              </div>
              <div class="col-md-2">
                <div><%= a.petName %></div>
                <div class="text-muted small"><%= a.livingSpace %>, <%= a.familyMembers %> members</div>
              </div>
              <div class="col-md-2">
                <span class="badge <%=
                    a.stage === 'Approved' ? 'bg-success' :
                    a.stage === 'Rejected' ? 'bg-danger' :
                    'bg-secondary'
                  %>"><%= a.stage %></span>
              </div>
              <div class="col-md-5">
                <form action="/applications/<%= a.id %>/stage" method="POST" class="d-flex gap-2 flex-wrap align-items-center">
                  <input type="text" name="decisionNotes" class="form-control form-control-sm flex-grow-1" placeholder="Notes (optional)" value="<%= a.decisionNotes || '' %>" style="min-width:140px;">
                  <button type="submit" name="stage" value="Approved" class="btn btn-sm btn-success">Approve</button>
                  <button type="submit" name="stage" value="Rejected" class="btn btn-sm btn-danger">Reject</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
