<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Manage Applications - Pet Shelter Portal</title>
</head>

<body>
  <%- include('header') %>

    <div class="container mt-4">
      <% if (typeof errors !=='undefined' && errors && errors.length> 0) { %>
        <div class="alert alert-danger">
          <% errors.forEach(function(e) { %>
            <p class="mb-0">
              <%= e %>
            </p>
            <% }); %>
        </div>
        <% } %>
          <% if (typeof messages !=='undefined' && messages && messages.length> 0) { %>
            <div class="alert alert-success">
              <% messages.forEach(function(m) { %>
                <p class="mb-0">
                  <%= m %>
                </p>
                <% }); %>
            </div>
            <% } %>
              <h2 class="text-center mb-4">Manage Adoption Applications</h2>
              <% if (applications.length===0) { %>
                <div class="alert alert-info text-center mt-4">
                  🎉 All caught up! There are currently no pending adoption applications to review.
                </div>
                <% } %>
                  <div class="d-flex flex-column gap-3">
                    <% applications.forEach(a=> { %>
                      <div class="card shadow-sm">
                        <div class="card-body">
                          <div class="row align-items-center gy-2">

                            <!-- Applicant & Timestamp -->
                            <div class="col-md-3">
                              <div class="fw-semibold">
                                <%= a.applicantName %>
                              </div>
                              <div class="text-muted small">
                                <%= a.applicantEmail %>
                              </div>
                              <div class="text-secondary small mt-1">
                                Submitted: <%= new Date(a.createdAt).toLocaleString('en-US', { dateStyle: 'medium' ,
                                  timeStyle: 'short' }) %>
                              </div>
                            </div>

                            <!-- Pet & Living Summary -->
                            <div class="col-md-2">
                              <div><strong>
                                  <%= a.petName %>
                                </strong></div>
                              <div class="text-muted small">
                                <%= a.livingSpace %>, <%= a.familyMembers %> member(s)
                              </div>
                            </div>

                            <!-- Stage Badge -->
                            <div class="col-md-2">
                              <span class="badge <%=
                    a.stage === 'Approved' ? 'bg-success' :
                    a.stage === 'Rejected' ? 'bg-danger' :
                    'bg-secondary'
                  %>">
                                <%= a.stage %>
                              </span>
                            </div>

                            <!-- Decision Action Form -->
                            <div class="col-md-5">
                              <form action="/applications/<%= a.id %>/stage" method="POST"
                                class="d-flex gap-2 flex-wrap align-items-center">
                                <input type="text" name="decisionNotes" class="form-control form-control-sm flex-grow-1"
                                  placeholder="Notes (optional)" value="<%= a.decisionNotes || '' %>"
                                  style="min-width:140px;">
                                <button type="submit" name="stage" value="Approved"
                                  class="btn btn-sm btn-success">Approve</button>
                                <button type="submit" name="stage" value="Rejected"
                                  class="btn btn-sm btn-danger">Reject</button>
                              </form>
                            </div>

                          </div>

                          <!-- COLLAPSIBLE SECTION FOR ALL HIDDEN QUESTIONS -->
                          <div class="mt-3 border-top pt-2">
                            <button class="btn btn-link btn-sm p-0 text-decoration-none" type="button"
                              data-bs-toggle="collapse" data-bs-target="#details-<%= a.id %>">
                              🔍 View Full Application Details
                            </button>

                            <div class="collapse mt-2" id="details-<%= a.id %>">
                              <div class="p-3 bg-light rounded small">
                                <div class="row g-2">
                                  <div class="col-md-4"><strong>Working Hours:</strong>
                                    <%= a.workingHours %>
                                  </div>
                                  <div class="col-md-4"><strong>Has Children:</strong>
                                    <%= a.hasChildren ? 'Yes' : 'No' %>
                                  </div>
                                  <div class="col-md-4"><strong>Activity Level:</strong>
                                    <%= a.activityLevel %>
                                  </div>
                                  <div class="col-md-6"><strong>Existing Pets:</strong>
                                    <%= a.existingPets || 'None' %>
                                  </div>
                                  <div class="col-md-12"><strong>Experience:</strong>
                                    <%= a.experience || 'None specified' %>
                                  </div>
                                  <div class="col-md-12"><strong>Motivation:</strong>
                                    <%= a.motivation || 'None specified' %>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                        </div>
                      </div>
                      <% }) %>
                  </div>
    </div>
      <a href="/applications/history" class="btn btn-link mt-4 d-block text-center">
        View Application History
      </a>
</body>

</html>