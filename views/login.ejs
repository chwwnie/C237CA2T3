<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Login - Pet Shelter Portal</title>
  <style>
    .auth-shell { min-height: 100vh; display: flex; }
    .auth-panel {
      background: linear-gradient(155deg, var(--color-primary) 0%, var(--color-primary-dark) 60%, #a8452c 100%);
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem;
      position: relative;
      overflow: hidden;
    }
    .auth-panel::before {
      content: "🐾";
      position: absolute;
      font-size: 22rem;
      opacity: 0.08;
      right: -3rem;
      bottom: -4rem;
      transform: rotate(-15deg);
    }
    .auth-panel .brand {
      font-weight: 800;
      font-size: 1.4rem;
      margin-bottom: auto;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .auth-panel h2 { font-size: 2.2rem; line-height: 1.2; margin-bottom: 1rem; }
    .auth-panel p.lead-text { font-size: 1.05rem; opacity: 0.9; max-width: 380px; }
    .auth-stats { display: flex; gap: 2.5rem; margin-top: 3rem; }
    .auth-stats div strong { display: block; font-size: 1.6rem; font-weight: 800; }
    .auth-stats div span { font-size: 0.85rem; opacity: 0.85; }
    .auth-form-side { display: flex; align-items: center; justify-content: center; padding: 2rem; }
    .auth-form-inner { width: 100%; max-width: 400px; }
    @media (max-width: 767.98px) { .auth-panel { display: none; } }
  </style>
</head>
<body>
  <div class="auth-shell">
    <div class="col-md-5 auth-panel">
      <div class="brand"><span style="font-size:1.6rem;">🐾</span> Pet Shelter Portal</div>
      <h2>Every pet deserves<br>a second chance.</h2>
      <p class="lead-text">Log back in to keep track of your applications, favourites, and the pets waiting to meet you.</p>
      <div class="auth-stats">
        <div><strong>100%</strong><span>Rescue pets</span></div>
        <div><strong>24/7</strong><span>Applications open</span></div>
        <div><strong>0$</strong><span>Adoption fee*</span></div>
      </div>
    </div>

    <div class="col-md-7 auth-form-side">
      <div class="auth-form-inner">
        <h1 class="h3 mb-1">Welcome back</h1>
        <p class="text-muted mb-4">Log in to continue your adoption journey.</p>

        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-danger" role="alert" aria-live="polite">
            <% errors.forEach(function(error) { %>
              <p class="mb-0"><%= error %></p>
            <% }); %>
          </div>
        <% } %>
        <% if (messages && messages.length > 0) { %>
          <div class="alert alert-success" role="alert" aria-live="polite">
            <% messages.forEach(function(message) { %>
              <p class="mb-0"><%= message %></p>
            <% }); %>
          </div>
        <% } %>

        <form action="/login" method="POST" id="loginForm">
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-control" required>
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
              <input type="password" id="password" name="password" class="form-control" required>
              <button class="btn btn-outline-secondary toggle-password" type="button" data-target="password">Show</button>
            </div>
          </div>
          <div class="d-grid mt-4">
            <button type="submit" class="btn btn-primary btn-lg" id="loginSubmit">Login</button>
          </div>
        </form>

        <p class="text-center mt-4 mb-0">
          Don't have an account? <a href="/register">Register here</a>
        </p>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.toggle-password').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const input = document.getElementById(btn.dataset.target);
        const showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        btn.textContent = showing ? 'Show' : 'Hide';
      });
    });

    document.getElementById('loginForm').addEventListener('submit', function () {
      document.getElementById('loginSubmit').disabled = true;
    });
  </script>
</body>
</html>
