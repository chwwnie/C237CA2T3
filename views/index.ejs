<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Pet Shelter Portal</title>
</head>
<body>
  <%- include('header') %>

  <div class="container mt-5 text-center">
    <img src="/images/index_image.jpg" class="img-fluid mb-4" alt="Pet Shelter">
    <h1>Welcome to the Pet Shelter Portal</h1>
    <p class="lead">Find your new best friend and help give a rescued pet a loving home.</p>
    <% if (user) { %>
      <a href="/pets" class="btn btn-primary btn-lg">Start Browsing Pets</a>
    <% } else { %>
      <a href="/login" class="btn btn-primary btn-lg">Login to Get Started</a>
    <% } %>
  </div>
</body>
</html>
