<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Application History - Pet Shelter Portal</title>
</head>
<body>
    <%- include('header') %>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="page-heading mb-0">
        <div class="icon-badge">📜</div>
        <div>
          <h2>Application History</h2>
          <p>Past decisions on adoption applications.</p>
        </div>
      </div>
      <a href="/applications" class="btn btn-outline-secondary">← Back to Pending</a>
    </div>

    <% if (applications.length === 0) { %>
      <div class="empty-state">
        <div class="icon">📜</div>
        <p>No history yet</p>
        <p class="small">Approved and rejected applications will show up here.</p>
      </div>
    <% } %>

    <div class="d-flex flex-column gap-3">
      <% applications.forEach(a => { %>
        <div class="card shadow-sm">
          <div class="card-body">
            <div class="row align-items-center gy-2">
              
              <!-- Applicant & Timestamp -->
              <div class="col-md-3">
                <div class="fw-semibold"><%= a.applicantName %></div>
                <div class="text-muted small"><%= a.applicantEmail %></div>
                <div class="text-secondary small mt-1">
                  Submitted: <%= new Date(a.createdAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                </div>
              </div>

              <!-- Pet & Living Summary -->
              <div class="col-md-3">
                <div><strong><%= a.petName %></strong></div>
                <div class="text-muted small"><%= a.livingSpace %>, <%= a.familyMembers %> members</div>
              </div>

              <!-- Final Status & Notes -->
              <div class="col-md-6">
                <div class="d-flex align-items-center gap-2 mb-1">
                  <span class="badge <%= a.stage === 'Approved' ? 'bg-success' : 'bg-danger' %>">
                    <%= a.stage %>
                  </span>
                  <span class="text-muted small">
                    Decided on: <%= new Date(a.updatedAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                  </span>
                </div>
                <% if (a.decisionNotes) { %>
                  <div class="bg-light p-2 rounded small text-dark mt-1">
                    <strong>Admin Notes:</strong> "<%= a.decisionNotes %>"
                  </div>
                <% } else { %>
                  <div class="text-muted small italic">No notes provided.</div>
                <% } %>
              </div>

            </div>

            <!-- COLLAPSIBLE FULL ANSWERS -->
            <div class="mt-3 border-top pt-2">
              <button class="btn btn-link btn-sm p-0 text-decoration-none" type="button" data-bs-toggle="collapse" data-bs-target="#details-<%= a.id %>">
                🔍 View Full Application Details
              </button>
              
              <div class="collapse mt-2" id="details-<%= a.id %>">
                <div class="p-3 bg-light rounded small">
                  <div class="row g-2">
                    <div class="col-md-4"><strong>Working Hours:</strong> <%= a.workingHours %></div>
                    <div class="col-md-4"><strong>Has Children:</strong> <%= a.hasChildren ? 'Yes' : 'No' %></div>
                    <div class="col-md-4"><strong>Activity Level:</strong> <%= a.activityLevel %></div>
                    <div class="col-md-6"><strong>Existing Pets:</strong> <%= a.existingPets || 'None' %></div>
                    <div class="col-md-12"><strong>Experience:</strong> <%= a.experience || 'None specified' %></div>
                    <div class="col-md-12"><strong>Motivation:</strong> <%= a.motivation || 'None specified' %></div>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>