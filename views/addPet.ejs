<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Add Pet - Pet Shelter Portal</title>
</head>
<body>
  <%- include('header') %>

  <div class="container mt-4" style="max-width: 760px;">
    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(e) { %><p class="mb-0"><%= e %></p><% }); %>
      </div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(m) { %><p class="mb-0"><%= m %></p><% }); %>
      </div>
    <% } %>

    <div class="page-heading">
      <div class="icon-badge">🐾</div>
      <div>
        <h2>Add a New Pet</h2>
        <p>Fill in the details below to list them for adoption.</p>
      </div>
    </div>

    <div class="form-card">
      <form action="/addPet" method="POST" enctype="multipart/form-data">

        <fieldset>
          <legend>Basic Info</legend>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Name</label>
              <input type="text" class="form-control" name="name" required>
            </div>
            <div class="col-md-6">
              <label class="form-label">Species</label>
              <select class="form-select" name="species" required>
                <option value="Dog">Dog</option>
                <option value="Cat">Cat</option>
                <option value="Rabbit">Rabbit</option>
                <option value="Bird">Bird</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Breed</label>
              <input type="text" class="form-control" name="breed" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Age (months)</label>
              <input type="number" class="form-control" name="ageMonths" min="0" required>
            </div>
            <div class="col-md-3">
              <label class="form-label">Age Group</label>
              <select class="form-select" name="ageGroup" required>
                <option value="Baby">Baby</option>
                <option value="Young">Young</option>
                <option value="Adult">Adult</option>
                <option value="Senior">Senior</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="col-md-4">
              <label class="form-label">Gender</label>
              <select class="form-select" name="gender" required>
                <option value="Male">Male</option>
                <option value="Female">Female</option>
                <option value="Unknown">Unknown</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label">Weight (lbs)</label>
              <input type="number" step="0.1" class="form-control" name="weightLbs" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Adoption Status</label>
              <select class="form-select" name="adoptionStatus">
                <option value="Available">Available</option>
                <option value="Pending">Pending</option>
                <option value="Adopted">Adopted</option>
                <option value="Medical Hold">Medical Hold</option>
              </select>
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>About This Pet</legend>
          <div class="mb-3">
            <label class="form-label">Personality</label>
            <textarea class="form-control" name="personality" rows="2" required></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" name="description" rows="3" required></textarea>
          </div>
          <div class="mb-0">
            <label class="form-label">Medical History</label>
            <textarea class="form-control" name="medicalHistory" rows="2"></textarea>
          </div>
        </fieldset>

        <fieldset>
          <legend>Shelter Details</legend>
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Vaccination Status</label>
              <input type="text" class="form-control" name="vaccinationStatus" placeholder="e.g. Fully Vaccinated">
            </div>
            <div class="col-md-6">
              <label class="form-label">Rescue Date</label>
              <input type="date" class="form-control" name="rescueDate">
            </div>
          </div>
          <div class="row">
            <div class="col-md-6">
              <label class="form-label">Shelter Location</label>
              <input type="text" class="form-control" name="shelterLocation">
            </div>
            <div class="col-md-6">
              <label class="form-label">Kennel Code</label>
              <input type="text" class="form-control" name="kennelCode">
            </div>
          </div>
        </fieldset>

        <fieldset>
          <legend>Temperament &amp; Health</legend>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithPeople" id="friendlyWithPeople">
            <label class="form-check-label" for="friendlyWithPeople">Good with people</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithKids" id="friendlyWithKids">
            <label class="form-check-label" for="friendlyWithKids">Good with kids</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithDogs" id="friendlyWithDogs">
            <label class="form-check-label" for="friendlyWithDogs">Good with dogs</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithCats" id="friendlyWithCats">
            <label class="form-check-label" for="friendlyWithCats">Good with cats</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" name="friendlyWithOtherPets" id="friendlyWithOtherPets">
            <label class="form-check-label" for="friendlyWithOtherPets">Good with other pets</label>
          </div>
          <br>
          <div class="form-check form-check-inline mt-2">
            <input class="form-check-input" type="checkbox" name="specialNeeds" id="specialNeeds">
            <label class="form-check-label" for="specialNeeds">Special needs</label>
          </div>
          <div class="form-check form-check-inline mt-2">
            <input class="form-check-input" type="checkbox" name="healthy" id="healthy" checked>
            <label class="form-check-label" for="healthy">Currently healthy</label>
          </div>
        </fieldset>

