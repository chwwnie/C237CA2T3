<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Register - Pet Shelter Portal</title>
  <style>
    body { background: #f4f1ea; }
    .auth-card { max-width: 480px; margin: 3rem auto; }
    .auth-card .card { border: none; border-radius: 1rem; box-shadow: 0 0.5rem 1.5rem rgba(0,0,0,0.08); }
    .auth-icon { font-size: 2.5rem; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">🐾 Pet Shelter Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav">
          <li class="nav-item"><a class="nav-link" href="/register">Register</a></li>
          <li class="nav-item"><a class="nav-link" href="/login">Login</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="auth-card">
    <div class="card">
      <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
          <div class="auth-icon">🐶🐱</div>
          <h1 class="h3 mt-2 mb-1">Create an Account</h1>
          <p class="text-muted">Join the shelter community and help pets find homes.</p>
        </div>

        <% if (messages && messages.length > 0) { %>
          <div class="alert alert-danger" role="alert" aria-live="polite">
            <% messages.forEach(function(message) { %>
              <p class="mb-0"><%= message %></p>
            <% }); %>
          </div>
        <% } %>

        <form action="/register" method="POST" id="registerForm" novalidate>
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" id="username" name="username" class="form-control" value="<%= formData ? formData.username : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-control" value="<%= formData ? formData.email : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
              <input type="password" id="password" name="password" class="form-control" minlength="6" required>
              <button class="btn btn-outline-secondary toggle-password" type="button" data-target="password">Show</button>
            </div>
            <div class="form-text">At least 6 characters.</div>
          </div>
          <div class="mb-3">
            <label for="confirmPassword" class="form-label">Confirm Password</label>
            <div class="input-group">
              <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" minlength="6" required>
              <button class="btn btn-outline-secondary toggle-password" type="button" data-target="confirmPassword">Show</button>
            </div>
            <div class="form-text text-danger d-none" id="passwordMismatch">Passwords do not match.</div>
          </div>
          <div class="mb-3">
            <label for="phone" class="form-label">Phone</label>
            <input type="text" id="phone" name="phone" class="form-control" value="<%= formData ? formData.phone : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="address" class="form-label">Address</label>
            <input type="text" id="address" name="address" class="form-control" value="<%= formData ? formData.address : '' %>" required>
          </div>
          <div class="mb-4">
            <!-- TESTING ONLY: remove this role dropdown before final submission
                 so new visitors can't self-register as admin. -->
            <label for="role" class="form-label">Role (testing only)</label>
            <select id="role" name="role" class="form-select">
              <option value="user">User</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg" id="registerSubmit">Register</button>
          </div>
        </form>

        <p class="text-center mt-4 mb-0">
          Already have an account? <a href="/login">Log in here</a>
        </p>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.toggle-password').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const input = document.getElementById(btn.dataset.target);
        const showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        btn.textContent = showing ? 'Show' : 'Hide';
      });
    });

    const form = document.getElementById('registerForm');
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirmPassword');
    const mismatchNote = document.getElementById('passwordMismatch');

    form.addEventListener('submit', function (e) {
      if (password.value !== confirmPassword.value) {
        e.preventDefault();
        mismatchNote.classList.remove('d-none');
        confirmPassword.focus();
      } else {
        mismatchNote.classList.add('d-none');
        document.getElementById('registerSubmit').disabled = true;
      }
    });
  </script>
</body>
</html>
