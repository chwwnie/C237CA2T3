<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Register - Pet Shelter Portal</title>
  <style>
    .auth-shell { min-height: 100vh; display: flex; }
    .auth-panel {
      background: linear-gradient(155deg, var(--color-secondary) 0%, var(--color-secondary-dark) 65%, #3f5643 100%);
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 4rem 3.5rem;
      position: relative;
      overflow: hidden;
    }
    .auth-panel::before {
      content: "🐶";
      position: absolute;
      font-size: 20rem;
      opacity: 0.10;
      right: -2rem;
      bottom: -3rem;
      transform: rotate(10deg);
    }
    .auth-panel .brand {
      font-weight: 800;
      font-size: 1.4rem;
      margin-bottom: auto;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .auth-panel h2 { font-size: 2.1rem; line-height: 1.25; margin-bottom: 1rem; }
    .auth-panel p.lead-text { font-size: 1.05rem; opacity: 0.92; max-width: 380px; }
    .auth-checklist { margin-top: 2.5rem; list-style: none; padding: 0; }
    .auth-checklist li { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.85rem; opacity: 0.95; }
    .auth-checklist li span.icon {
      background: rgba(255,255,255,0.15);
      width: 28px; height: 28px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.85rem; flex-shrink: 0;
    }
    .auth-form-side { display: flex; align-items: center; justify-content: center; padding: 2rem; }
    .auth-form-inner { width: 100%; max-width: 420px; }
    @media (max-width: 767.98px) { .auth-panel { display: none; } }
  </style>
</head>
<body>
  <div class="auth-shell">
    <div class="col-md-5 auth-panel">
      <div class="brand"><span style="font-size:1.6rem;">🐾</span> Pet Shelter Portal</div>
      <h2>Your new best friend<br>is waiting.</h2>
      <p class="lead-text">Create an account to save favourites, submit adoption applications, and track their progress in one place.</p>
      <ul class="auth-checklist">
        <li><span class="icon">✓</span> Browse dogs, cats, rabbits &amp; more</li>
        <li><span class="icon">✓</span> Track your applications in real time</li>
        <li><span class="icon">✓</span> Get notified the moment you're approved</li>
      </ul>
    </div>

    <div class="col-md-7 auth-form-side">
      <div class="auth-form-inner">
        <h1 class="h3 mb-1">Create your account</h1>
        <p class="text-muted mb-4">Join the shelter community and help pets find homes.</p>

        <% if (messages && messages.length > 0) { %>
          <div class="alert alert-danger" role="alert" aria-live="polite">
            <% messages.forEach(function(message) { %>
              <p class="mb-0"><%= message %></p>
            <% }); %>
          </div>
        <% } %>

        <form action="/register" method="POST" id="registerForm" novalidate>
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" id="username" name="username" class="form-control" value="<%= formData ? formData.username : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" class="form-control" value="<%= formData ? formData.email : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
              <input type="password" id="password" name="password" class="form-control" minlength="6" required>
              <button class="btn btn-outline-secondary toggle-password" type="button" data-target="password">Show</button>
            </div>
            <div class="form-text">At least 6 characters.</div>
          </div>
          <div class="mb-3">
            <label for="confirmPassword" class="form-label">Confirm Password</label>
            <div class="input-group">
              <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" minlength="6" required>
              <button class="btn btn-outline-secondary toggle-password" type="button" data-target="confirmPassword">Show</button>
            </div>
            <div class="form-text text-danger d-none" id="passwordMismatch">Passwords do not match.</div>
          </div>
          <div class="mb-3">
            <label for="phone" class="form-label">Phone</label>
            <input type="text" id="phone" name="phone" class="form-control" value="<%= formData ? formData.phone : '' %>" required>
          </div>
          <div class="mb-3">
            <label for="address" class="form-label">Address</label>
            <input type="text" id="address" name="address" class="form-control" value="<%= formData ? formData.address : '' %>" required>
          </div>
          <div class="d-grid mt-4">
            <button type="submit" class="btn btn-primary btn-lg" id="registerSubmit">Register</button>
          </div>
        </form>

        <p class="text-center mt-4 mb-0">
          Already have an account? <a href="/login">Log in here</a>
        </p>
      </div>
    </div>
  </div>

  <script>
    document.querySelectorAll('.toggle-password').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const input = document.getElementById(btn.dataset.target);
        const showing = input.type === 'text';
        input.type = showing ? 'password' : 'text';
        btn.textContent = showing ? 'Show' : 'Hide';
      });
    });

    const form = document.getElementById('registerForm');
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirmPassword');
    const mismatchNote = document.getElementById('passwordMismatch');

    form.addEventListener('submit', function (e) {
      if (password.value !== confirmPassword.value) {
        e.preventDefault();
        mismatchNote.classList.remove('d-none');
        confirmPassword.focus();
      } else {
        mismatchNote.classList.add('d-none');
        document.getElementById('registerSubmit').disabled = true;
      }
    });
  </script>
</body>
</html>
