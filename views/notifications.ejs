<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Notifications - Pet Shelter Portal</title>
</head>
<body>
  <%- include('header') %>

  <div class="container mt-4" style="max-width: 700px;">
    <div class="page-heading">
      <div class="icon-badge">🔔</div>
      <div>
        <h2>Notifications</h2>
        <p>Updates on your adoption applications.</p>
      </div>
    </div>

    <% if (notifications.length === 0) { %>
      <div class="empty-state">
        <div class="icon">🔔</div>
        <p>You have no notifications yet.</p>
        <p class="small">Updates on your adoption applications will show up here.</p>
      </div>
    <% } %>

    <div class="d-flex flex-column gap-2">
      <% notifications.forEach(n => { %>
        <div class="card shadow-sm" style="<%= n.isRead ? '' : 'border-left: 4px solid var(--color-primary);' %>">
          <div class="card-body py-3 d-flex justify-content-between align-items-start gap-3">
            <div>
              <p class="mb-1"><%= n.message %></p>
              <div class="text-muted small"><%= n.createdAt.toLocaleString() %></div>
            </div>
            <% if (!n.isRead) { %>
              <span class="badge bg-primary rounded-pill flex-shrink-0">New</span>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
