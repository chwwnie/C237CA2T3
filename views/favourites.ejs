<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>My Favourites - Pet Shelter Portal</title>
</head>
<body>
  <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">Pet Shelter Portal</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="collapsibleNavbar">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link" href="/pets">Browse Pets</a></li>
          <li class="nav-item"><a class="nav-link" href="/favourites">Favourites</a></li>
          <li class="nav-item"><a class="nav-link" href="/my-applications">My Applications</a></li>
          <% if (user.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/addPet">Add Pet</a></li>
            <li class="nav-item"><a class="nav-link" href="/applications">Manage Applications</a></li>
          <% } %>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
              👤 <%= user.username %> <% if (typeof unreadCount !== 'undefined' && unreadCount > 0) { %><span class="badge rounded-pill bg-danger"><%= unreadCount %></span><% } %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenuDropdown">
              <li><a class="dropdown-item" href="/notifications">🔔 Notifications</a></li>
              <li><a class="dropdown-item" href="/profile">My Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2 class="text-center mb-4">My Favourite Pets</h2>
    <div class="row">
      <% if (pets.length === 0) { %>
        <p class="text-center">You have not favourited any pets yet.</p>
      <% } %>
      <% pets.forEach(pet => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <img src="/images/<%= pet.image || 'placeholder.png' %>" class="card-img-top" style="height:200px; object-fit:cover;" alt="<%= pet.name %>">
            <div class="card-body">
              <h5 class="card-title"><a href="/pets/<%= pet.id %>"><%= pet.name %></a></h5>
              <p class="card-text mb-1"><%= pet.breed %> &middot; <%= pet.ageGroup %></p>
              <span class="badge bg-secondary"><%= pet.adoptionStatus %></span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
