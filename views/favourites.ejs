<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>My Favourites - Pet Shelter Portal</title>
</head>
<body>
 <%- include('header') %>

  <div class="container mt-4">
    <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(e) { %><p class="mb-0"><%= e %></p><% }); %>
      </div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages && messages.length > 0) { %>
      <div class="alert alert-success">
        <% messages.forEach(function(m) { %><p class="mb-0"><%= m %></p><% }); %>
      </div>
    <% } %>
    <h2 class="text-center mb-4">My Favourite Pets</h2>
    <div class="row">
      <% if (pets.length === 0) { %>
        <p class="text-center">You have not favourited any pets yet.</p>
      <% } %>
      <% pets.forEach(pet => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <img src="/images/pet/<%= pet.id %>" class="card-img-top" style="height:200px; object-fit:cover; object-position:top;" alt="<%= pet.name %>">
            <div class="card-body">
              <h5 class="card-title"><a href="/pets/<%= pet.id %>"><%= pet.name %></a></h5>
              <p class="card-text mb-1"><%= pet.breed %> &middot; <%= pet.ageGroup %></p>
              <span class="badge <%= 
                      pet.adoptionStatus === 'Available' ? 'bg-success' : 
                      pet.adoptionStatus === 'Pending' ? 'bg-warning text-dark' : 
                      pet.adoptionStatus === 'Adopted' ? 'bg-danger' : 
                      pet.adoptionStatus === 'Medical Hold' ? 'bg-info text-dark' : 
                      'bg-secondary' 
                    %>">
                    <%= pet.adoptionStatus %>
                  </span>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
