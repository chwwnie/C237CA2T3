<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <!-- ADD THIS LINE BELOW -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <title>Browse Pets - Pet Shelter Portal</title>
</head>

<style>
  .fav-btn:hover .bi-heart {
    color: #dc3545 !important
  }

  ;
</style>

<body>
  <%- include('header') %>

  <div class="container mt-4">
    <% if (typeof errors !=='undefined' && errors && errors.length> 0) { %>
      <div class="alert alert-danger">
        <% errors.forEach(function(e) { %>
          <p class="mb-0">
            <%= e %>
          </p>
          <% }); %>
      </div>
      <% } %>
        <% if (typeof messages !=='undefined' && messages && messages.length> 0) { %>
          <div class="alert alert-success">
            <% messages.forEach(function(m) { %>
              <p class="mb-0">
                <%= m %>
              </p>
              <% }); %>
          </div>
          <% } %>
            <div class="page-heading">
              <div class="icon-badge">🐾</div>
              <div>
                <h2><%= query.status ? query.status + ' Pets' : 'Available Pets' %></h2>
                <p>Find your new best friend.</p>
              </div>
            </div>

            <!-- Search / Filter form -->
            <form action="/pets" method="GET" class="row g-2 search-bar-card">
              <div class="col-md-3">
                <input type="text" name="q" class="form-control" placeholder="Search by name or breed"
                  value="<%= query.q || '' %>">
              </div>
              <div class="col-md-2">
                <select name="species" class="form-select">
                  <option value="">All Species</option>
                  <% ['Dog','Cat','Rabbit','Bird','Other'].forEach(s=> { %>
                    <option value="<%= s %>" <%=query.species===s ? 'selected' : '' %>><%= s %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="col-md-2">
                <select name="ageGroup" class="form-select">
                  <option value="">All Ages</option>
                  <% ['Baby','Young','Adult','Senior'].forEach(a=> { %>
                    <option value="<%= a %>" <%=query.ageGroup===a ? 'selected' : '' %>><%= a %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="col-md-2">
                <select name="status" class="form-select">
                  <option value="">All Statuses</option>
                  <% ['Available','Pending','Adopted','Medical Hold'].forEach(st=> { %>
                    <option value="<%= st %>" <%=query.status===st ? 'selected' : '' %>><%= st %>
                    </option>
                    <% }) %>
                </select>
              </div>
              <div class="col-md-2">
                <select name="sort" class="form-select">
                  <option value="">Newest First</option>
                  <option value="name" <%=query.sort==='name' ? 'selected' : '' %>>Name (A-Z)</option>
                  <option value="age" <%=query.sort==='age' ? 'selected' : '' %>>Youngest First</option>
                </select>
              </div>
              <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Go</button>
              </div>
            </form>

            <div class="row">
              <% if (pets.length===0) { %>
                <div class="empty-state">
                  <div class="icon">🔍</div>
                  <p>No pets match your search</p>
                  <p class="small">Try adjusting your filters.</p>
                </div>
                <% } %>
                  <% pets.forEach(pet=> { %>
                    <div class="col-md-4 mb-4">
                      <div class="card h-100">
                        <!-- Image & Floating Heart Container -->
                        <div class="position-relative">
                          <img src="/images/pet/<%= pet.id %>" class="card-img-top"
                            style="height:200px; object-fit:cover; object-position:top;" alt="<%= pet.name %>">

                          <!-- Toggle Favourite Form -->
                          <% const isFav=(typeof favouritePetIds !=='undefined' ) && favouritePetIds.includes(pet.id);
                            %>
                            <form action="/pets/<%= pet.id %>/favourite" method="POST"
                              class="position-absolute top-0 end-0 m-2">
                              <button type="submit"
                                class="btn btn-light btn-sm rounded-circle shadow-sm border-0 d-flex align-items-center justify-content-center fav-btn"
                                style="width: 36px; height: 36px; background: rgba(255, 255, 255, 0.9);"
                                title="<%= isFav ? 'Remove from Favourites' : 'Add to Favourites' %>">
                                <i
                                  class="bi <%= isFav ? 'bi-heart-fill text-danger' : 'bi-heart text-secondary' %> fs-6"></i>
                              </button>
                            </form>
                        </div>
                        <div class="card-body">
                          <h5 class="card-title"><a href="/pets/<%= pet.id %>">
                              <%= pet.name %>
                            </a></h5>
                          <p class="card-text mb-1">
                            <%= pet.breed %> &middot; <%= pet.ageGroup %> &middot; <%= pet.gender %>
                          </p>
                          <span class="badge <%= 
                      pet.adoptionStatus === 'Available' ? 'bg-success' : 
                      pet.adoptionStatus === 'Pending' ? 'bg-warning text-dark' : 
                      pet.adoptionStatus === 'Adopted' ? 'bg-danger' : 
                      pet.adoptionStatus === 'Medical Hold' ? 'bg-info text-dark' : 
                      'bg-secondary' 
                    %>">
                            <%= pet.adoptionStatus %>
                          </span>
                        </div>
                      </div>
                    </div>
                    <% }) %>
            </div>
  </div>
</body>

</html>